{
  "name": "frescoop-uemoa-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npm run start",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm run start",
    "install:web": "cd frontend && npm install && cd ../backend && npm install",
    "install:all": "npm run install:web && cd mobile && npm install",
    "test": "node scripts/smoke-test.mjs",
    "test:unit": "cd frontend && npm run test:unit -- --root .. tests/server",
    "migrate:atlas": "node scripts/import-store-to-mongodb.mjs"
  }
}
