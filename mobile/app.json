{
  "expo": {
    "name": "FresCoop UEMOA",
    "slug": "frescoop-uemoa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.frescoop.uemoa"
    },
    "android": {
      "package": "com.frescoop.uemoa",
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20"
      }
    },
    "platforms": ["ios", "android"],
    "plugins": ["expo-asset", "expo-secure-store"]
  }
}
